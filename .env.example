NODE_ENV=development
PORT=4000
# Comma-separated list (e.g. http://localhost:5173,http://127.0.0.1:5173) or "*" for any origin
CORS_ORIGIN=*
# Max upload size in megabytes (applies to /api/uploads)
MAX_UPLOAD_MB=50

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/webrtc_project

# JWT / tokens (use strong secrets in production)
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_12345
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_12345
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=rt
COOKIE_SECURE=false
# COOKIE_DOMAIN=localhost

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/google/callback

# WebRTC ICE servers (optional TURN)
STUN_URLS=stun:stun.l.google.com:19302
# TURN_URLS=turn:your.turn.server:3478?transport=udp,turn:your.turn.server:3478?transport=tcp
# TURN_USERNAME=
# TURN_CREDENTIAL=

# Call ringing timeout (server will mark missed)
CALL_RING_TIMEOUT_SECONDS=30
